{
  "__inputs": [
    {
      "name": "DS_TIMESCALEDB",
      "label": "TimescaleDB",
      "description": "TimescaleDB PostgreSQL datasource",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "IoT Sensor Analytics – real-time sensor data from TimescaleDB",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "celsius" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT bucket AS time, device_id AS metric, avg_temperature AS value\nFROM hourly_stats\nWHERE $__timeFilter(bucket)\nORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "title": "Temperature – Hourly Average by Device",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT bucket AS time, device_id AS metric, avg_humidity AS value\nFROM hourly_stats\nWHERE $__timeFilter(bucket)\nORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "title": "Humidity – Hourly Average by Device",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 15 },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT device_id AS metric, temperature AS \"value\"\nFROM device_latest\nORDER BY device_id",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Current Temperature by Device",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "misc" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT COUNT(*) AS value FROM devices WHERE is_active = true",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Active Devices",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "misc" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT COUNT(*) AS value FROM alerts WHERE is_resolved = false",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Active Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "rawSql": "SELECT bucket AS time, device_id AS metric, reading_count AS value\nFROM hourly_stats\nWHERE $__timeFilter(bucket)\nORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "title": "Readings per Hour by Device",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["iot", "timescaledb", "sensors"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IoT Sensor Analytics",
  "uid": "iot-sensor-analytics",
  "version": 1
}
